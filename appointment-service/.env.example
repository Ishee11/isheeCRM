# Application
APP_PORT=8080
APP_CONTAINER_NAME=appointment-service-app-container
APP_IMAGE=ghcr.io/ishee11/isheecrm-appointment-service
IMAGE_TAG=latest

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=isheecrm

# Postgres container for local/dev compose
POSTGRES_IMAGE=postgres:17.6-bookworm
POSTGRES_CONTAINER_NAME=postgres-container
POSTGRES_PORT=5432
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=isheecrm
POSTGRES_DATA_DIR=/var/lib/isheecrm/postgres
POSTGRES_BACKUP_DIR=/var/backups/isheecrm
POSTGRES_BACKUP_RETENTION_DAYS=7
APP_NETWORK_NAME=appointment-service_app-network
